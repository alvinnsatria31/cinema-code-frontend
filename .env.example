# ── Live API (DEMO_MODE is false — pages fetch the Express backend) ──
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Server-to-server URL for NextAuth's user sync (falls back to the above)
API_URL="http://localhost:4000"
NEXT_PUBLIC_DEMO_USER_ID=""

# Google emails that get the ADMIN role (must match the server's list)
ADMIN_EMAILS="alvinatmaja23@gmail.com"

# ── NextAuth (Google sign-in) ───────────────────────────────
# All optional in local offline preview: without them the app runs in
# demo mode with the mock "Andin" profile.
# Generate: openssl rand -base64 32
AUTH_SECRET=""
# From https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: {origin}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Only needed behind a proxy / custom domain (Vercel sets this itself)
# AUTH_URL="https://your-app.vercel.app"
